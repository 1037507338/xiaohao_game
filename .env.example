# 复制为 .env.local 并填入真实值；生产在 Vercel 环境变量里配置同名项
LLM_BASE_URL=https://api.niceai.io/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-5.4-mini
# 1 = 用 LLM 算分；其它值或留空 = 用本地 mock 规则
USE_LLM_SCORER=1
# token 加密密钥，生产务必换成随机字符串（如 openssl rand -base64 32）
GAME_TOKEN_SECRET=change-me
# Upstash Redis 结果缓存（可选）。留空则用进程内存缓存，配置后跨实例共享。
# 在 Vercel 接入 Upstash 后会自动注入这两个变量。
KV_REST_API_URL=
KV_REST_API_TOKEN=
